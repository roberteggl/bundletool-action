{
  "name": "bundletool-action",
  "description": "Convert Android App Bundles (.aab) to APKs using Google bundletool",
  "version": "0.0.0",
  "author": "Robert Eggl",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "homepage": "https://github.com/roberteggl/bundletool-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roberteggl/bundletool-action.git"
  },
  "bugs": {
    "url": "https://github.com/roberteggl/bundletool-action/issues"
  },
  "keywords": [
    "actions",
    "android",
    "bundletool",
    "aab",
    "apk"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "bundle": "pnpm format:write && pnpm package",
    "ci-test": "vitest run --coverage",
    "coverage": "make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "biome check --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "local-action": "local-action . src/main.ts .env",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "pnpm package -- --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "all": "pnpm format:write && pnpm lint && pnpm test && pnpm coverage && pnpm package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@github/local-action": "^7.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^3.2.4",
    "make-coverage-badge": "^1.2.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.57.1",
    "vitest": "^3.2.4",
    "typescript": "^7.0.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
