{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:biomeVersions",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":semanticCommitScope(deps)"
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Keep @biomejs/biome and biome.json $schema in one PR",
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "@biomejs/biome"
    },
    {
      "description": "Group non-major pnpm development dependency updates",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": ["!@biomejs/biome"],
      "groupName": "pnpm devDependencies (non-major)"
    },
    {
      "description": "Group patch updates for pnpm production dependencies",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "groupName": "pnpm dependencies (patch)"
    },
    {
      "description": "Group all GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Rebundle dist/ after production dependency updates",
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "postUpgradeTasks": {
        "commands": ["pnpm install", "pnpm bundle"],
        "fileFilters": ["dist/**"]
      }
    }
  ]
}
